п»ҝ# й–«ж°ұж•Ө
TZ=Australia/Sydney

# Postgres
POSTGRES_DB=coinmark
POSTGRES_USER=coinmark
POSTGRES_PASSWORD=coinmark
DATABASE_URL=postgresql+asyncpg://coinmark:coinmark@postgres:5432/coinmark

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Hubй”ӣеңөebSocket йҺәг„©вӮ¬дҫҠзҙҡ
HUB_ENABLED=true
HUB_ALLOWED_ORIGINS=*
HUB_MAX_CONNECTIONS=1000
HUB_HEARTBEAT_TIMEOUT_SEC=45
HUB_HEARTBEAT_INTERVAL_SEC=15
HUB_DEDUPE_WINDOW_SEC=60
HUB_BROADCAST_MAX_EVENTS_PER_SEC=200
HUB_ANOMALY_SCAN_INTERVAL_SEC=2
HUB_ANOMALY_SCAN_BATCH_SIZE=200

# Ingestй”ӣе қеҸҸй–Іеҝҡо…№й—ғе‘°з·қй–Іе¶Ҹзҙҡ
INGEST_ENABLE_SPOT=true
INGEST_ENABLE_SWAP=true
INGEST_ENABLE_DEPTH=true
INGEST_TRADE_SOURCE_SPOT=nats
INGEST_TRADE_SOURCE_SWAP=nats
INGEST_DEPTH_SOURCE_SPOT=nats
INGEST_DEPTH_SOURCE_SWAP=nats
INGEST_NATS_URL=nats://nats:4222
INGEST_NATS_STREAM_RAW=COINMARK_RAW
INGEST_NATS_SUBJECT_TRADE=coinmark.raw.trade
INGEST_NATS_SUBJECT_DEPTH=coinmark.raw.depth
INGEST_NATS_CONSUMER_PREFIX=coinmark-ingest
INGEST_SYMBOL_UNIVERSE=all_usdt
INGEST_SYMBOL_LIMIT=0
INGEST_STREAMS_PER_CONN=200
INGEST_DEPTH_UPDATE_MS=100
INGEST_FLUSH_INTERVAL_SEC=2
INGEST_DB_BATCH_SIZE=1200
INGEST_SYMBOL_REFRESH_INTERVAL_HOURS=6
INGEST_RUNTIME_REPORT_INTERVAL_SEC=30

# йҚҸг„©еҷәйҚҰзғҳж«ҷеҜӨйёҝоҶ…йҚҸжҠҪжЈҙйҚҡоҲҡе§©йҚҘзӮІпҪһй”ӣеІ„жӘ·жөЈеәЎеҳІйҚҠз…Һе”ҙзҖӣ?
BACKFILL_ENABLE=false
BACKFILL_1M_LIMIT=0
BACKFILL_TOP_N=120
BACKFILL_CONCURRENCY=8
BACKFILL_15M_LIMIT=200
BACKFILL_1H_LIMIT=200
BACKFILL_4H_LIMIT=180
BACKFILL_1D_LIMIT=60

# OI йҚ’й”ӢжҹҠ
OI_REFRESH_TOP_N=300
OI_REFRESH_INTERVAL_SEC=300

# йҸҖоҲӣжӢәй—ғиҜІе§ҸйҚ’й”ӢжҹҠ
SR_REFRESH_TOP_N=200
SR_REFRESH_INTERVAL_SEC=1800

# еҜ®еӮҡе§©йҺөоӮЈејҝ
ANOMALY_SCAN_TOP_N=200
ANOMALY_SCAN_INTERVAL_SEC=60
ANOMALY_HISTORY_15M=96
ANOMALY_BREAKOUT_MARGIN_PCT=0.001
ANOMALY_VOLUME_SPIKE_FACTOR=3.0
ANOMALY_AMPLITUDE_SPIKE_FACTOR=2.5

# й–Іеҝҡе…ҳйҺәжҺ•о”‘
RANK_BUCKET=15m
RANK_HISTORY_BUCKETS=96
RANK_MIN_AVG_NOTIONAL=1000

# з”ҜеӮҡвӮ¬е…јжҪөе©§?
MARKET_CAP_SOURCE=binance_bapi_get_products

# Telegram Botй”ӣе қеј» Botй”ӣж°¶вӮ¬ж°ұз…Ў + йҸҢгғЁоҮ—й”ӣ?TG_ENABLED=false
TG_NOTIFY_BOT_TOKEN=
TG_QUERY_BOT_TOKEN=
TG_NOTIFY_CHAT_ID=
TG_NOTIFY_MARKET=swap
TG_NOTIFY_POLL_INTERVAL_SEC=5
TG_NOTIFY_BATCH_WINDOW_SEC=30
TG_NOTIFY_BATCH_MAX_ITEMS=5
TG_NOTIFY_MIN_LEVEL=warning
TG_QUERY_POLL_TIMEOUT_SEC=25
TG_STATE_REDIS_PREFIX=coinmark:tg

# Collector-Go (NATS JetStream)
COLLECTOR_NATS_URL=nats://nats:4222
COLLECTOR_NATS_STREAM_RAW=COINMARK_RAW
COLLECTOR_NATS_SUBJECT_TRADE=coinmark.raw.trade
COLLECTOR_NATS_SUBJECT_DEPTH=coinmark.raw.depth
COLLECTOR_NATS_CLIENT_NAME=collector-go



