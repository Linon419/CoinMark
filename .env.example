# 閫氱敤
TZ=Australia/Sydney

# SQLite（API/TG 小事务 + API 读库）
DATABASE_URL=sqlite+aiosqlite:////data/app.db

# ClickHouse（行情镜像/分析）
CLICKHOUSE_URL=http://clickhouse:8123
INGEST_CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=default
CLICKHOUSE_USER=coinmark
CLICKHOUSE_PASSWORD=coinmark

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Hub锛圵ebSocket 鎺ㄩ€侊級
HUB_ENABLED=true
HUB_ALLOWED_ORIGINS=*
HUB_MAX_CONNECTIONS=1000
HUB_HEARTBEAT_TIMEOUT_SEC=45
HUB_HEARTBEAT_INTERVAL_SEC=15
HUB_DEDUPE_WINDOW_SEC=60
HUB_BROADCAST_MAX_EVENTS_PER_SEC=200
HUB_ANOMALY_SCAN_INTERVAL_SEC=2
HUB_ANOMALY_SCAN_BATCH_SIZE=200

# 深度全扫描（按币种分层轮询 REST 深度）
DEPTH_FULLSCAN_ENABLED=false
DEPTH_FULLSCAN_MARKET=swap
DEPTH_FULLSCAN_LIMIT_SWAP=1000
DEPTH_FULLSCAN_LIMIT_SPOT=5000
DEPTH_FULLSCAN_SYMBOLS=BTC,ETH,BNB,SOL,DOGE,LTC,LDO,CRV,LINK,ADA,UNI,ONDO,AAVE,AVAX,1000PEPE,SUI,SEI,WLD,HYPE,TRUMP,PUMP,ZEC
DEPTH_FULLSCAN_FAST_SYMBOLS=BTC,ETH,BNB,SOL
DEPTH_FULLSCAN_FAST_INTERVAL_SEC=300
DEPTH_FULLSCAN_SLOW_INTERVAL_SEC=900
DEPTH_FULLSCAN_CONCURRENCY=4
DEPTH_FULLSCAN_JITTER_SEC=45

# Ingest锛堝叏閲忚闃呰緝閲嶏級
INGEST_ENABLE_SPOT=true
INGEST_ENABLE_SWAP=true
INGEST_ENABLE_DEPTH=true
INGEST_NATS_URL=nats://nats:4222
INGEST_NATS_STREAM_RAW=COINMARK_RAW
INGEST_NATS_SUBJECT_TRADE=coinmark.raw.trade
INGEST_NATS_SUBJECT_DEPTH=coinmark.raw.depth
INGEST_NATS_CONSUMER_PREFIX=coinmark-ingest
INGEST_SYMBOL_UNIVERSE=all_usdt
INGEST_SYMBOL_LIMIT=0
INGEST_STREAMS_PER_CONN=200
INGEST_DEPTH_UPDATE_MS=100
INGEST_FLUSH_INTERVAL_SEC=2
INGEST_DB_BATCH_SIZE=1200
INGEST_SYMBOL_REFRESH_INTERVAL_HOURS=6
INGEST_RUNTIME_REPORT_INTERVAL_SEC=30

# collector runtime tuning
COLLECTOR_DEPTH_UPDATE_MS_SWAP=500
COLLECTOR_DEPTH_UPDATE_MS_SPOT=1000
COLLECTOR_SYMBOL_LIMIT=200

# 鍏ㄩ噺鍦烘櫙寤鸿鍏抽棴鍚姩鍥炲～锛岄檷浣庡嘲鍊煎唴瀛?
BACKFILL_ENABLE=false
BACKFILL_SYMBOLS=
BACKFILL_1M_LIMIT=0
BACKFILL_TOP_N=120
BACKFILL_CONCURRENCY=8
BACKFILL_15M_LIMIT=200
BACKFILL_1H_LIMIT=200
BACKFILL_4H_LIMIT=180
BACKFILL_1D_LIMIT=60

# trade_buckets 1m watchdog (WS fallback to REST)
BUCKET_WATCHDOG_ENABLE=true
BUCKET_WATCHDOG_INTERVAL_SEC=60
BUCKET_WATCHDOG_TOP_N=120
BUCKET_WATCHDOG_WINDOW_MIN=10
BUCKET_WATCHDOG_MAX_REPAIR_MIN=180
BUCKET_WATCHDOG_COOLDOWN_SEC=90
BUCKET_WATCHDOG_DIFF_CHECK_TOP_N=120
BUCKET_WATCHDOG_DIFF_CHECK_BATCH=10
BUCKET_WATCHDOG_HOT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# OI 鍒锋柊
OI_REFRESH_TOP_N=300
OI_REFRESH_INTERVAL_SEC=300

# 鏀拺闃诲姏鍒锋柊

# 寮傚姩鎵弿

# 閲忚兘鎺掕
RANK_BUCKET=15m
RANK_HISTORY_BUCKETS=96
RANK_MIN_AVG_NOTIONAL=1000

# 甯傚€兼潵婧?
MARKET_CAP_SOURCE=binance_bapi_get_products

# Telegram Bot锛堝弻 Bot锛氶€氱煡 + 鏌ヨ锛?TG_ENABLED=false
TG_NOTIFY_BOT_TOKEN=
TG_QUERY_BOT_TOKEN=
TG_NOTIFY_CHAT_ID=
TG_NOTIFY_ADMIN_CHAT_ID=
TG_NOTIFY_MARKET=swap
TG_NOTIFY_POLL_INTERVAL_SEC=5
TG_NOTIFY_BATCH_WINDOW_SEC=30
TG_NOTIFY_BATCH_MAX_ITEMS=5
TG_NOTIFY_MIN_LEVEL=warning
TG_QUERY_POLL_TIMEOUT_SEC=25
TG_STATE_REDIS_PREFIX=coinmark:tg

# Collector-Go (NATS JetStream)
COLLECTOR_NATS_URL=nats://nats:4222
COLLECTOR_NATS_STREAM_RAW=COINMARK_RAW
COLLECTOR_NATS_SUBJECT_TRADE=coinmark.raw.trade
COLLECTOR_NATS_SUBJECT_DEPTH=coinmark.raw.depth
COLLECTOR_NATS_CLIENT_NAME=collector-go



